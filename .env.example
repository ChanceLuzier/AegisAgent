# Aegis AI — environment configuration
# Copy this file to .env and adjust values for your machine.
# All settings are optional — defaults work out of the box.

# ----------------------------
# Paths
# ----------------------------
# AEGIS_DIRECTOR_DIR=C:\AI\AegisAgent   # project root (default: auto-detected)

# ----------------------------
# Ollama
# ----------------------------
# OLLAMA_CHAT_URL=http://127.0.0.1:11434/api/chat
# OLLAMA_MODEL=llama3.1:8b

# ----------------------------
# Voice / TTS (Kokoro)
# ----------------------------
# KOKORO_VOICE=af_heart   # voices: af_heart, af_bella, am_adam, bf_emma, bm_george
# KOKORO_GPU=0            # set to 1 to use GPU acceleration
# KOKORO_PREWARM=0        # set to 1 to load Kokoro at startup (faster first response)
# VOICE_SR=24000

# ----------------------------
# Agent behaviour
# ----------------------------
# AEGIS_MODE=semi           # semi = approval required for destructive ops | auto = fully autonomous
# AGENT_MAX_ITERS=5

# ----------------------------
# Safety / guardrails
# ----------------------------
# AEGIS_ALLOWED_ROOTS=C:\AI\AegisAgent   # semicolon-separated list of allowed filesystem roots
# AEGIS_MAX_READ_BYTES=200000
# AEGIS_MAX_WRITE_BYTES=400000
# AEGIS_PROCESS_TIMEOUT_SEC=45

# ----------------------------
# UI
# ----------------------------
# UI_MAX_BUBBLES=300
# AUTO_VOICE_DEFAULT_ON=1
